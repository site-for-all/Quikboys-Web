# Delivery Backend API (NestJS)
# Local development
VITE_DELIVERY_API_URL=http://localhost:3001/api/v1
# Production/Staging — uses /api/v1 relative URL via Amplify proxy (no env var needed)

# AWS CloudWatch RUM (optional — analytics)
# Set these in Amplify Console environment variables
VITE_CW_RUM_APP_ID=
VITE_CW_RUM_IDENTITY_POOL_ID=
VITE_CW_RUM_ENDPOINT=
VITE_CW_RUM_REGION=ap-south-1
